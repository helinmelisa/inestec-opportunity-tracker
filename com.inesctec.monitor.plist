<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.inesctec.monitor</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-c</string>
    <string>cd /Users/helinergezen/inesctec_monitor &amp;&amp; python3 monitor.py</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/helinergezen/inesctec_monitor</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/helinergezen/inesctec_monitor/monitor.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/helinergezen/inesctec_monitor/monitor.log</string>
</dict>
</plist>
